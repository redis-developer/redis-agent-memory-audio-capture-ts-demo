{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@config/*": ["./src/config/*"],
      "@memory/*": ["./src/memory/*"],
      "@models/*": ["./src/models/*"],
      "@enricher/*": ["./src/enricher/*"]
    }
  },
  "references": [{ "path": "../shared" }],
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
