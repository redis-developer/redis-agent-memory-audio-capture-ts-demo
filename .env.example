# Redis Agent Memory settings
MEMORY_API_HOST=https://your.agent.memory.redis.io
MEMORY_API_KEY=mem1_your-awesome-key
MEMORY_STORE_ID=memory-store-id-from-redis

# OpenAI secrets
OPENAI_API_KEY=sk-proj-your-awesome-key

# Identifies the user in chatbot session memory and sets
# the session's owner for stored memories.
USER_NAME=alice

# Owner under which listeners store audio in long-term
# memory. If unset, each listener picks its own default
# ('earshot-listener' for the radio listener,
# 'earshot-mic-listener' for the mic listener). Set this
# only if you want both listeners to share an owner.
LISTENER_OWNER_ID=


#
# Audio capture settings
#

# Audio capture device — avfoundation index or name.
# run npm run audio:devices to get a list.
AUDIO_DEVICE=Your Sound Card

# Folder where audio snippets are saved.
AUDIO_OUTPUT_DIR=./captures

# Free-form context about the location of the audio source.
# Fed into text correctors to help fix misheard local
# proper nouns. Optional. Good for radio listening.
AUDIO_LOCATION_CONTEXT="Receiver is in Newington, Connecticut (Hartford County, grid FN31pr). Nearby places: Hartford, New Britain, West Hartford, Berlin, Wethersfield. Local clubs: ARRL HQ (W1AW), Newington ARL. Common 2m repeaters: 146.94, 147.18, 145.45."


#
# Rig and radio settings when listening on amateur radio
#

# Serial port for rigctl to use when listening from a
# radio. run npm run rig:devices to list ports
RIG_PORT=/dev/cu.usbserial-01600C6F0

# Baud rate for serial port
RIG_BAUD=38400

# Hamlib rig model. See `rigctl --list`.
RIG_MODEL=1035
