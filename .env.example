# Redis Agent Memory settings
MEMORY_API_HOST=https://your.agent.memory.redis.io
MEMORY_API_KEY=mem1_your-awesome-key
MEMORY_STORE_ID=memory-store-id-from-redis

# OpenAI secrets
OPENAI_API_KEY=sk-proj-your-awesome-key

# Identifies the user in chatbot session memory and sets
# the session's owner for stored memories.
USER_NAME=alice

# Owner under which listeners store audio in long-term
# memory, and the owner the chatbot searches. All three
# processes default to 'earshot-listener', so they already
# agree if you leave this unset. Override it here if you
# want to scope captures under a different owner.
LISTENER_OWNER_ID=earshot-listener


#
# Mic-listener audio capture settings
#

# Audio capture device — avfoundation index or name.
# run npm run devices to get a list.
MIC_AUDIO_DEVICE=Your Sound Card

# Folder where audio snippets are saved.
MIC_AUDIO_OUTPUT_DIR=./captures/mic

# Free-form context about the location of the audio source.
# Fed into the text corrector to help fix misheard local
# proper nouns. Optional.
MIC_AUDIO_LOCATION_CONTEXT="Microphone is in the lobby of Acme HQ, 500 Main St, Columbus, Ohio. Common names: Acme, the Atrium, the West Wing."


#
# Radio settings when listening on amateur radio
#

# Audio capture device — avfoundation index or name.
# run npm run devices to get a list.
RADIO_AUDIO_DEVICE=Your Sound Card

# Folder where audio snippets are saved.
RADIO_AUDIO_OUTPUT_DIR=./captures/radio

# Free-form context about the location of the audio source.
# Fed into the text corrector to help fix misheard local
# proper nouns. Optional. Good for radio listening.
RADIO_AUDIO_LOCATION_CONTEXT="Receiver is in Newington, Connecticut (Hartford County, grid FN31pr). Nearby places: Hartford, New Britain, West Hartford, Berlin, Wethersfield. Local clubs: ARRL HQ (W1AW), Newington ARL. Common 2m repeaters: 146.94, 147.18, 145.45."

# Serial port for rigctl to use when listening from a
# radio. run npm run devices to list ports
RIG_PORT=/dev/cu.usbserial-01600C6F0

# Baud rate for serial port
RIG_BAUD=38400

# Hamlib rig model. See `rigctl --list`.
RIG_MODEL=1035
